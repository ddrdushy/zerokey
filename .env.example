# Copy to .env and fill in. Never commit .env.
#
# This file holds ONLY the values that must be present at process boot:
# settings module, connection strings, root credentials. Everything that
# the super-admin should be able to rotate at runtime — vendor API keys,
# integration credentials — lives in the database and is edited from the
# operations console (Django admin until the dedicated UI lands).
#
# The DB-stored values fall back to the matching env var below if they
# are unset, so a fresh deployment still boots before the super-admin
# has populated anything. Once a value is set in the DB, the env var
# stops mattering.

# --- Required: process boot ---------------------------------------------------

# Django
DJANGO_SETTINGS_MODULE=zerokey.settings.dev
DJANGO_SECRET_KEY=change-me-to-a-50-char-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Postgres (connection — needed before any DB-backed setting can be read)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=zerokey
POSTGRES_USER=zerokey
POSTGRES_PASSWORD=zerokey_dev
# The app role is separate from the superuser; RLS policies apply to it.
POSTGRES_APP_USER=zerokey_app
POSTGRES_APP_PASSWORD=zerokey_app_dev

# Redis (broker, cache, sessions)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Qdrant
QDRANT_URL=http://qdrant:6333

# Frontend (baked at build time — must be env)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# AWS / KMS (root credentials we use to fetch other secrets)
AWS_REGION=ap-southeast-5
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
KMS_KEY_ALIAS=alias/zerokey-cert-envelope

# --- Optional: bootstrap fallbacks for DB-managed secrets ---------------------
#
# These are read only when the corresponding DB row has no value. Production
# deployments should leave these blank and configure via the operations
# console. Local dev can fill them in to skip the console step.
#
# Per-engine credentials (managed in extraction.Engine.credentials):
#   ANTHROPIC_API_KEY            → Engine("anthropic-claude-sonnet-vision").credentials.api_key
#                                   and Engine("anthropic-claude-sonnet-structure").credentials.api_key
#   OLLAMA_HOST                  → Engine("ollama-structure").credentials.host
#                                   (default http://host.docker.internal:11434 for local;
#                                   set https://ollama.com for cloud)
#   OLLAMA_API_KEY               → Engine("ollama-structure").credentials.api_key
#                                   (required for cloud, blank for local)
#   OLLAMA_MODEL                 → Engine("ollama-structure").credentials.model
#                                   (e.g. gpt-oss:120b, gemini-3-flash-preview, gemma3:12b)
#   AZURE_DOC_INTELLIGENCE_KEY   → (Azure adapter row, not yet wired)
#   OPENAI_API_KEY               → (OpenAI adapter row, not yet wired)
#
# Platform-wide integration credentials (managed in administration.SystemSetting):
#   LHDN_BASE_URL                → SystemSetting("lhdn").values.base_url
#   LHDN_CLIENT_ID               → SystemSetting("lhdn").values.client_id
#   LHDN_CLIENT_SECRET           → SystemSetting("lhdn").values.client_secret
#   STRIPE_SECRET_KEY            → SystemSetting("stripe").values.secret_key
#   STRIPE_WEBHOOK_SECRET        → SystemSetting("stripe").values.webhook_secret

ANTHROPIC_API_KEY=
OLLAMA_HOST=
OLLAMA_API_KEY=
OLLAMA_MODEL=
AZURE_DOC_INTELLIGENCE_ENDPOINT=
AZURE_DOC_INTELLIGENCE_KEY=
OPENAI_API_KEY=

LHDN_BASE_URL=https://preprod-api.myinvois.hasil.gov.my
LHDN_CLIENT_ID=
LHDN_CLIENT_SECRET=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
